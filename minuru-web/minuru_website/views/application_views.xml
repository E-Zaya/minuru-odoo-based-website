<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_minuru_application_tree" model="ir.ui.view">
        <field name="name">minuru.application.tree</field>
        <field name="model">minuru.application</field>
        <field name="arch" type="xml">
            <tree string="Expedition Applications" decoration-muted="state == 'declined'" decoration-success="state == 'confirmed'">
                <field name="submitted_at"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="country"/>
                <field name="expedition"/>
                <field name="group_size"/>
                <field name="preferred_month"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_minuru_application_form" model="ir.ui.view">
        <field name="name">minuru.application.form</field>
        <field name="model">minuru.application</field>
        <field name="arch" type="xml">
            <form string="Expedition Application">
                <header>
                    <button name="action_mark_contacted" string="Mark Contacted" type="object" class="btn-primary" invisible="state != 'new'"/>
                    <button name="action_mark_confirmed" string="Confirm" type="object" class="btn-primary" invisible="state == 'confirmed'"/>
                    <button name="action_mark_declined" string="Decline" type="object" invisible="state == 'declined'"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,contacted,confirmed,declined"/>
                </header>
                <sheet>
                    <group>
                        <group string="Traveller">
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="country"/>
                            <field name="age"/>
                            <field name="group_size"/>
                        </group>
                        <group string="Expedition">
                            <field name="expedition"/>
                            <field name="preferred_month"/>
                            <field name="vip_service"/>
                            <field name="risk_accepted"/>
                            <field name="submitted_at" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Experience">
                            <field name="offroad_experience"/>
                            <field name="driving_experience"/>
                            <field name="physical_fitness"/>
                        </group>
                        <group string="Source">
                            <field name="source_url"/>
                            <field name="user_agent"/>
                        </group>
                    </group>
                    <group string="Expectations">
                        <field name="expectations" nolabel="1"/>
                    </group>
                    <group string="Special Requests">
                        <field name="special_requests" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_minuru_application_search" model="ir.ui.view">
        <field name="name">minuru.application.search</field>
        <field name="model">minuru.application</field>
        <field name="arch" type="xml">
            <search string="Applications">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="country"/>
                <field name="expedition"/>
                <filter name="new" string="New" domain="[('state', '=', 'new')]"/>
                <filter name="contacted" string="Contacted" domain="[('state', '=', 'contacted')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_expedition" string="Expedition" context="{'group_by': 'expedition'}"/>
                    <filter name="group_month" string="Preferred Month" context="{'group_by': 'preferred_month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_minuru_applications" model="ir.actions.act_window">
        <field name="name">Expedition Applications</field>
        <field name="res_model">minuru.application</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_new': 1}</field>
    </record>

    <menuitem id="menu_minuru_root" name="Minuru Website" sequence="80"/>
    <menuitem id="menu_minuru_applications" name="Applications" parent="menu_minuru_root" action="action_minuru_applications" sequence="10"/>
</odoo>
